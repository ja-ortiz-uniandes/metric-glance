# Installed tooling: large, regenerated by `npm install`, never committed.
node_modules/

# Local wrangler state and any local secrets file: never commit.
.wrangler/
.dev.vars
*.log
.DS_Store

# Your repo-root .gitignore (written for the extension, which has no build step)
# ignores package.json and package-lock.json. In THIS backend subfolder we do
# want both tracked, so re-include them. Deeper .gitignore rules win.
!package.json
!package-lock.json
